# Copy this file to .env and fill in your credentials.
# Never commit .env — it is gitignored.

# OpenAI — used for cluster renaming + BUILD/WATCH/SKIP decisions
OPENAI_API_KEY=sk-...

# Brave Search API — competitor check (1,000 free queries/month)
# https://brave.com/search/api/
BRAVE_SEARCH_KEY=BSA...

# GitHub — pushes each daily briefing to modryn-studio-v2 to trigger a Vercel rebuild
# Fine-grained PAT: Contents read+write on modryn-studio-v2 only
# Generate at: github.com → Settings → Developer settings → Fine-grained personal access tokens
GITHUB_TOKEN=github_pat_...

# Gmail IMAP — Google Trends newsletter ingest
# Use an App Password, not your main account password.
# Generate at: myaccount.google.com → Security → App passwords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
